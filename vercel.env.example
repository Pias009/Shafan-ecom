# Vercel Environment Variables Template
# Copy these to Vercel Project Settings → Environment Variables

# ========================
# CORE CONFIGURATION
# ========================

# Next.js Configuration
NODE_ENV=production
NEXT_PUBLIC_VERCEL_ENV=production

# NextAuth.js
NEXTAUTH_URL=https://your-domain.vercel.app
NEXTAUTH_SECRET=generate-with: openssl rand -base64 32

# ========================
# DATABASE
# ========================

# MongoDB Atlas
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# ========================
# PAYMENT PROCESSING
# ========================

# Stripe (Live Keys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ========================
# EMAIL SERVICE
# ========================

# Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM="Shafan Store <your-email@gmail.com>"

# Admin Notifications
ADMIN_EMAIL=admin@example.com

# ========================
# MEDIA & FILE UPLOADS
# ========================

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ========================
# CACHING
# ========================

# Redis (Upstash recommended for Vercel)
REDIS_URL=rediss://default:password@upstash-redis-url:6379

# Cache TTLs (seconds)
CACHE_TTL_SHORT=60
CACHE_TTL_MEDIUM=300
CACHE_TTL_LONG=3600

# ========================
# APPLICATION FEATURES
# ========================

# Admin Panel Control
ACTIVE_ADMIN_PANELS=true

# Kuwait Store Configuration
KUWAIT_STORE_CODE=KUW
KUWAIT_ADMIN_EMAIL=kuwait-admin@example.com
KUWAIT_ADMIN_PASSWORD=secure-password

# Demo Users (Optional)
DEMO_SUPERADMIN_EMAIL=superadmin@example.com
DEMO_SUPERADMIN_PASSWORD=superadmin123
DEMO_ADMIN_EMAIL=admin@example.com
DEMO_ADMIN_PASSWORD=admin123

# ========================
# COURIER INTEGRATION
# ========================

# Courier API (Future Integration)
COURIER_PROVIDER=aramex
COURIER_API_KEY=your-courier-api-key
COURIER_WEBHOOK_SECRET=your-courier-webhook-secret

# ========================
# SECURITY
# ========================

# Rate Limiting (Optional)
RATE_LIMIT_WINDOW=60000  # 1 minute in milliseconds
RATE_LIMIT_MAX_REQUESTS=100

# ========================
# REAL-TIME NOTIFICATIONS
# ========================

# Pusher WebSocket (Get from pusher.com)
PUSHER_APP_ID=2145513
PUSHER_KEY=1f774a5bbab3fae7abac
PUSHER_SECRET=20f78fcba81376802077
PUSHER_CLUSTER=ap2
NEXT_PUBLIC_PUSHER_KEY=1f774a5bbab3fae7abac
NEXT_PUBLIC_PUSHER_CLUSTER=ap2

# ========================
# MONITORING & ANALYTICS
# ========================

# Sentry (Optional)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/...
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Google Analytics (Optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ========================
# DEPLOYMENT NOTES
# ========================

# 1. Mark all variables as "Encrypted" in Vercel for security
# 2. Use different values for Production vs Preview environments
# 3. After setting variables, redeploy the project
# 4. Test all critical paths after deployment
# 5. Monitor error logs in Vercel Analytics