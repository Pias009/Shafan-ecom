datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum OrderStatus {
  ORDER_RECEIVED
  ORDER_CONFIRMED
  PROCESSING
  READY_FOR_PICKUP
  ORDER_PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

model Store {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  code      String   @unique
  name      String
  country   String
  region    String
  active    Boolean  @default(true)
  currency  String   @default("usd")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders           Order[]          @relation("StoreOrders")
  courierServices  CourierService[] @relation("StoreCouriers")
  products         Product[]        @relation("StoreProducts")
  storeInventories StoreInventory[] @relation("StoreInventories")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  passwordHash  String?
  country       String?
  isVerified    Boolean   @default(false)

  // MFA and Lockout
  loginAttempts Int       @default(0)
  lockUntil     DateTime?
  mfaEnabled    Boolean   @default(true) // Required per user request for admin

  // Super Admin Approval System
  requiresApproval Boolean @default(false)
  approvedBySuperAdmin Boolean @default(false)
  lastLoginAttempt DateTime?
  
  accounts       Account[]
  sessions       Session[]
  orders         Order[]
  address        Address?
  resetTokens    PasswordResetToken[]
  mfaTokens      MfaToken[]
  discountUsages DiscountUsage[]
  loginApprovals LoginApproval[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model MfaToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String   @unique
  expires   DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model LoginApproval {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminEmail    String
  adminName     String?
  storeCode     String?  // UAE or KUWAIT
  ipAddress     String?
  userAgent     String?
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedBy    String?  @db.ObjectId // Super admin who approved
  approvedAt    DateTime?
  rejectionReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String   @unique
  slug          String?  @unique
  description       String?
  shortDescription String?
  benefits         String?
  ingredients      String?
  howToUse         String?
  features         String[]
  images        String[]
  mainImage     String?
  stockQuantity Int      @default(0)
  priceCents    Int
  discountCents Int?
  active        Boolean  @default(true)
  hot           Boolean  @default(false)
  trending      Boolean  @default(false)
  sku           String?
  currency      String   @default("USD")
  averageRating Float    @default(0)
  ratingCount   Int      @default(0)
  totalSales    Int      @default(0)
  
  // SEO fields
  tags            String[]
  metaTitle       String?
  metaDescription String?

  storeId String? @db.ObjectId
  store   Store?  @relation(fields: [storeId], references: [id], name: "StoreProducts")

  brandId          String?           @db.ObjectId
  subCategoryId    String?           @db.ObjectId
  brand            Brand?            @relation(fields: [brandId], references: [id])
  subCategory      SubCategory?      @relation(fields: [subCategoryId], references: [id])
  orderItems       OrderItem[]
  storeInventories StoreInventory[]
  productDiscounts ProductDiscount[]
  countryPrices    CountryPrice[]

  productCategories ProductCategory[]
  productSkinTones  ProductSkinTone[]
  productSkinConcerns ProductSkinConcern[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductCategory {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  productId  String   @db.ObjectId
  categoryId String   @db.ObjectId
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([productId, categoryId])
  @@index([productId])
  @@index([categoryId])
}

model ProductSkinTone {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  productId  String   @db.ObjectId
  skinToneId String   @db.ObjectId
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  skinTone   SkinTone @relation(fields: [skinToneId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([productId, skinToneId])
  @@index([productId])
  @@index([skinToneId])
}

model SkinConcern {
  id                String             @id @default(auto()) @map("_id") @db.ObjectId
  name              String             @unique
  description       String?
  products          ProductSkinConcern[]
  createdAt         DateTime?
  updatedAt         DateTime?
}

model ProductSkinConcern {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  productId     String      @db.ObjectId
  skinConcernId String      @db.ObjectId
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  skinConcern   SkinConcern @relation(fields: [skinConcernId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([productId, skinConcernId])
  @@index([productId])
  @@index([skinConcernId])
}

model Brand {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String    @unique
  image     String? // Brand logo/image URL
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id                String             @id @default(auto()) @map("_id") @db.ObjectId
  name              String             @unique
  description       String?
  categoryDiscounts CategoryDiscount[]
  subCategories     SubCategory[]
  products          ProductCategory[]
  createdAt         DateTime?
  updatedAt         DateTime?
}

model SubCategory {
  id                String             @id @default(auto()) @map("_id") @db.ObjectId
  name              String             @unique
  description       String?
  categoryId        String             @db.ObjectId
  category          Category           @relation(fields: [categoryId], references: [id])
  products          Product[]
  createdAt         DateTime?
  updatedAt         DateTime?
}

model SkinTone {
  id                String             @id @default(auto()) @map("_id") @db.ObjectId
  name              String             @unique
  description       String?
  hexColor          String?            // Optional color representation
  products          ProductSkinTone[]
  createdAt         DateTime?
  updatedAt         DateTime?
}

model Order {
  id                    String          @id @default(auto()) @map("_id") @db.ObjectId
  storeId               String?         @db.ObjectId
  store                 Store?          @relation(fields: [storeId], references: [id], name: "StoreOrders")
  userId                String?         @db.ObjectId
  user                  User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  email                 String?
  status                OrderStatus     @default(ORDER_RECEIVED)
  currency              String          @default("usd")
  subtotalCents         Int
  shippingCents         Int             @default(0)
  discountCents         Int             @default(0)
  totalCents            Int
  paymentMethod         String?
  paymentMethodTitle    String?
  billingAddress        Json?
  shippingAddress       Json?
  stripePaymentIntentId String?
  tabbyPaymentId        String?
  tabbySessionId        String?
  tamaraCheckoutId      String?
  discountId            String?         @db.ObjectId // Applied discount
  discount              Discount?       @relation(fields: [discountId], references: [id])
  discountAmountCents   Int? // Amount saved from discount in cents
  items                 OrderItem[]
  shipment              Shipment?
  discountUsages        DiscountUsage[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model OrderItem {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  orderId        String  @db.ObjectId
  productId      String  @db.ObjectId
  quantity       Int
  unitPriceCents Int
  nameSnapshot   String
  imageSnapshot  String?
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product @relation(fields: [productId], references: [id])
}

model CourierService {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  storeId   String   @db.ObjectId
  store     Store    @relation(fields: [storeId], references: [id], name: "StoreCouriers")
  enabled   Boolean  @default(false)
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreInventory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  store     Store    @relation(fields: [storeId], references: [id], name: "StoreInventories")
  storeId   String   @db.ObjectId
  product   Product  @relation(fields: [productId], references: [id])
  productId String   @db.ObjectId
  quantity  Int
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, productId])
}

model OfferBanner {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl  String   @unique
  title     String?
  subtitle  String?
  link      String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EnhancedOfferBanner {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  // Core content
  imageUrl  String  @unique
  title     String?
  subtitle  String?
  offerText String? // e.g., "70% OFF" or "$50 OFF"
  ctaText   String? // Custom CTA button text

  // Visual customization
  backgroundColor String? // Hex color for background
  textColor       String? // Hex color for text
  backgroundImage String? // Alternative to imageUrl for full background

  // Scheduling
  startDate DateTime?
  endDate   DateTime?
  active    Boolean   @default(true)

  // Behavior
  link       String? // Product page URL or discount code
  discountId String?   @db.ObjectId // Associated discount
  discount   Discount? @relation(fields: [discountId], references: [id])

  // Display
  sortOrder Int @default(0)
  priority  Int @default(1) // 1=Low, 2=Medium, 3=High

  // Tracking
  clicks      Int @default(0)
  conversions Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, startDate, endDate])
  @@index([sortOrder])
}

model Discount {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  code        String? @unique // Optional discount code
  name        String // Display name
  description String?

  // Discount type and value
  discountType DiscountType @default(PERCENTAGE)
  value        Float // e.g., 20 for 20% or 15.50 for $15.50

  // Application scope
  applyToAll        Boolean @default(false)
  minimumOrderValue Int? // Minimum order amount in cents

  // Validity
  startDate DateTime?
  endDate   DateTime?
  maxUses   Int? // Maximum number of uses
  uses      Int       @default(0) // Current usage count

  // Status
  active    Boolean @default(true)
  autoApply Boolean @default(false) // Auto-apply to eligible products

  // Relationships
  productDiscounts  ProductDiscount[]
  categoryDiscounts CategoryDiscount[]
  banners           EnhancedOfferBanner[] // Banners that use this discount
  orders            Order[] // Orders that used this discount
  discountUsages    DiscountUsage[] // Usage tracking

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, startDate, endDate])
}

model ProductDiscount {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  productId  String   @db.ObjectId
  discountId String   @db.ObjectId
  product    Product  @relation(fields: [productId], references: [id])
  discount   Discount @relation(fields: [discountId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([productId, discountId])
  @@index([discountId])
}

model CategoryDiscount {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  categoryId String   @db.ObjectId
  discountId String   @db.ObjectId
  category   Category @relation(fields: [categoryId], references: [id])
  discount   Discount @relation(fields: [discountId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([categoryId, discountId])
  @@index([discountId])
}

model DiscountUsage {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  discountId  String   @db.ObjectId
  userId      String?  @db.ObjectId
  orderId     String?  @db.ObjectId
  email       String? // For guest users
  amountSaved Int // Amount saved in cents
  usedAt      DateTime @default(now())

  discount Discount @relation(fields: [discountId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])
  order    Order?   @relation(fields: [orderId], references: [id])

  @@index([discountId])
  @@index([userId])
  @@index([orderId])
}

model Address {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  userId     String  @unique @db.ObjectId
  fullName   String
  phone      String
  email      String
  country    String
  city       String
  address1   String
  address2   String?
  postalCode String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  userId  String   @db.ObjectId
  token   String   @unique
  expires DateTime
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  action    String
  actorId   String   @db.ObjectId
  subjectId String?  @db.ObjectId
  details   String?
  createdAt DateTime @default(now())
}

model Banner {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl  String   @unique
  title     String?
  link      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  slug       String   @unique
  excerpt    String?
  content    String?
  coverImage String?
  tags       String[]
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Shipment {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId      String   @unique @db.ObjectId
  courier      String
  trackingCode String
  trackingUrl  String?
  status       String   @default("Created")
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CountryPrice {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  productId   String   @db.ObjectId
  country     String   // Country code like "US", "BD", "KW", etc.
  priceCents  Int      // Price in cents for this country
  currency    String   @default("USD") // Currency code for this country
  active      Boolean  @default(true)
  
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([productId, country])
  @@index([country])
  @@index([productId])
}

model PerformanceMetric {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  value          Float
  unit           String   @default("ms")
  metadata       Json
  sessionId      String
  userAgent      String
  connectionType String?
  timestamp      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sessionId])
  @@index([name])
  @@index([timestamp])
}

// ==================== SUPER SECRET DEVELOPER PANEL ====================
// Master lock state for the entire website
model WebsiteLock {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  isLocked    Boolean  @default(false)
  lockedAt    DateTime?
  lockedBy    String?  // User ID or system identifier
  lockReason  String?
  unlockToken String   @unique // Cryptographic token required for unlock
  
  // Emergency bypass (only for extreme cases)
  emergencyBypassCode String? @unique
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([isLocked])
}

// Master authentication for the secret panel
model MasterAuth {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  masterId     String   @unique // Cryptographic master ID
  tokenHash    String   // Hashed authentication token
  salt         String   // Salt for token hashing
  lastUsed     DateTime?
  lastIp       String?
  isActive     Boolean  @default(true)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Audit logs for all lock/unlock actions
model LockAuditLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  action      String   // "LOCK", "UNLOCK", "LOGIN", "LOGOUT", "ACCESS_DENIED"
  masterId    String?  // Reference to MasterAuth
  ipAddress   String
  userAgent   String?
  metadata    Json?    // Additional context (userId, path, etc.)
  
  createdAt   DateTime @default(now())
  
  @@index([action])
  @@index([masterId])
  @@index([createdAt])
}

// Secret URL access tracking
model SecretAccessLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  path        String   // The secret path accessed
  ipAddress   String
  userAgent   String?
  success     Boolean  @default(false) // Whether access was granted
  reason      String?  // Reason for denial if success=false
  
  createdAt   DateTime @default(now())
  
  @@index([path])
  @@index([success])
  @@index([createdAt])
}
